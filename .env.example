# Rename this file to .env and fill in values before running locally.
# Backend API base URL — used by the Axios client.
# In development, Vite's proxy (/api → localhost:8080) means you can leave this
# as the proxy path. Set to the full URL when building for a non-proxied environment.
VITE_API_BASE_URL=http://localhost:8080/api/v1
